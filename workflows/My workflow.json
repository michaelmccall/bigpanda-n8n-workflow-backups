          "name": "Glean API"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Parse the Glean chat response\nconst gleanResponse = items[0].json;\n\n// Glean returns messages array; grab the last AGENT message\nconst messages = gleanResponse.messages || [];\nconst agentMsg  = [...messages].reverse().find(m => m.author === 'GLEAN_AGENT' || m.role === 'assistant') || messages[messages.length - 1];\n\n// Extract plain text from fragments\nlet draftText = '';\nif (agentMsg?.fragments) {\n  draftText = agentMsg.fragments.map(f => f.text || '').join('');\n} else if (agentMsg?.content) {\n  draftText = agentMsg.content;\n} else {\n  draftText = JSON.stringify(agentMsg);\n}\n\n// Carry forward task context from earlier in the chain\nconst taskId   = $node[\"Extract Task Info\"].json.taskId;\nconst taskName = $node[\"Extract Task Info\"].json.taskName;\nconst taskDesc = $node[\"Extract Task Info\"].json.taskDesc;\n\nreturn [{ json: { taskId, taskName, taskDesc, draftText } }];"
      },

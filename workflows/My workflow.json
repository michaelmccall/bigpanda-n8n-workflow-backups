    {
      "parameters": {
        "functionCode": "// Extract the key fields from the ClickUp task payload\nconst task = items[0].json.task || items[0].json;\n\nconst taskId   = task.id;\nconst taskName = task.name;\nconst taskDesc = task.description || task.text_content || '';\n\n// Pull any extra context from custom fields\nconst customFields = (task.custom_fields || []);\nconst extraContext = customFields\n  .filter(f => f.value)\n  .map(f => `${f.name}: ${f.value}`)\n  .join('\\n');\n\nreturn [{ json: { taskId, taskName, taskDesc, extraContext } }];"
      },
      "id": "92e543d0-6182-4654-89db-d68c32817a5a",
      "name": "Extract Task Info1",
      "type": "n8n-nodes-base.function",
